      "code_id": "1b88da35-e1b9-4ea2-8adb-c22023f44530",
      "code_content": "students_dict = {\n    \"Ram\": \"Cricket\",\n    \"Naresh\": \"Football\",\n    \"Vani\": \"Tennis\",\n    \"Rahim\": \"Cricket\"\n}\n\nkey, value = input().split()\nstudents_dict[key] = value\nprint(students_dict)\n",
