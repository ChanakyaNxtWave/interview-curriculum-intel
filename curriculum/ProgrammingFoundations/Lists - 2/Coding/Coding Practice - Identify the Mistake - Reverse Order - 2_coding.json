    {
      "code_id": "f6959c84-87a8-49db-b6b4-10941d29f88f",
      "code_content": "list_a = input().split(\",\")\nlist_b = input().split(\",\")\n\nlen_of_list_a = len(list_a)\nn = len_of_list_a - 1\n\nfor i in range(len_of_list_a):\n    num_1 = list_a[i]\n    num_2 = list_b[n-i]\n    result = str(num_1) + \" \" + str(num_2)\n    print(result)\n",
