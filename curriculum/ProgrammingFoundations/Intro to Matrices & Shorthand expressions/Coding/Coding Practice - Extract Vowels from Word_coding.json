    {
      "code_id": "f3461da7-e134-4ae7-b946-b0674c9db269",
      "code_content": "def extract_vowels(word):\n    vowels = \"aeiouAEIOU\"\n    return [char for char in word if char in vowels]\n\nword = input()\nvowel_list = extract_vowels(word)\nprint(\" \".join(vowel_list))",
