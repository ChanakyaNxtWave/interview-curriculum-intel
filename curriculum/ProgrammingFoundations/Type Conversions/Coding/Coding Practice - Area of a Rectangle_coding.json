    {
      "code_id": "c59b5b0d-c2e0-498c-b8a4-1f97be3261fa",
      "code_content": "length = input()\nbreadth = input()\n\nlength = int(length)\nbreadth = int(breadth)\n\narea = length * breadth\nprint(area)\n",
