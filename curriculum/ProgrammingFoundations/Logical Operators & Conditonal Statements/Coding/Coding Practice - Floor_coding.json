      "code_id": "d7510f6c-6359-4d1f-93a9-f2b34557bc35",
      "code_content": "room_number = input()\n\nnumber = room_number[1:]\nnumber = int(number)\n\nif (number < 30):\n    print(\"Ground Floor\")\nelse:\n    print(\"Not Ground Floor\")",
