      "code_id": "4992050b-bbf9-4d67-a81a-e639ec3610cd",
      "code_content": "first_num = input()\nsecond_num = input()\n\nfirst_num = float(first_num)\nsecond_num = float(second_num)\n\ndiff = first_num - second_num\nprint(diff)",
