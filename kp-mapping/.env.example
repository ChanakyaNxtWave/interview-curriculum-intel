# Primary LLM provider (OpenRouter)
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_MODEL=anthropic/claude-sonnet-4.5

# Fallback providers — used when an earlier provider in LLM_PROVIDER_ORDER fails
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile

GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-2.0-flash

# Try order on failure (at least one key required for the providers you list)
LLM_PROVIDER_ORDER=openrouter,groq,gemini

# Optional OpenRouter attribution headers
OPENROUTER_HTTP_REFERER=http://localhost
OPENROUTER_APP_TITLE=KP Mapping Workflow

# Review UI
KP_REVIEW_PORT=8765
KP_MAPPING_DB=./data/kp_mappings.db
KP_CATALOG_JSON=../curriculum/KPs-ProgrammingFoundations.json
